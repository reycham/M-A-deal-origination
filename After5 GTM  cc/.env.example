# Copy to .env and fill in. .env is gitignored.

# Prospeo (enrich-person, X-KEY header)
PROSPEO_API_KEY=

# MillionVerifier (bulk verification, key query param)
MV_API_KEY=

# Icypeas (HMAC-SHA1 signed bulk search + verification)
ICY_API_KEY=
ICY_API_SECRET=
ICY_USER_ID=

# Adyntel (Meta + Google ads intelligence — auths via JSON body, not header)
ADYNTEL_API_KEY=
ADYNTEL_EMAIL=

# Apify (SimilarWeb traffic data via crawlerbros/similarweb-scraper)
APIFY_API_TOKEN=
APIFY_SIMILARWEB_ACTOR_ID=1mg9l1E9DoFwjO17x

# Anthropic (Claude Haiku 4.5 for website summarisation in script 12)
ANTHROPIC_API_KEY=

# Firecrawl (homepage + about-page scraping in script 12)
FIRECRAWL_API_KEY=

# Smartlead (campaign creation/lead push via REST API)
SMARTLEAD_API_KEY=
